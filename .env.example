# =========================================================================
# AGENT NFS-E — Variáveis de ambiente
# =========================================================================
# Copie este arquivo pra .env e preencha com valores reais.
# NUNCA suba .env pro git. Adicione no .gitignore.

# --- SERVIDOR ---
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# --- DOMÍNIO ---
PUBLIC_URL=https://onboarding.com.br

# --- ANTHROPIC (extração de campos + classificador + agenda) ---
# Pega em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-5
# Overrides por feature:
# - Extractor de NFSe usa ANTHROPIC_MODEL (Sonnet por default — tarefa
#   complexa, precisa modelo capaz).
# - Classificador e Agenda têm DEFAULT PRÓPRIO em Haiku (tarefas simples,
#   roda em cada mensagem — Haiku é ~5x mais rápido com qualidade idêntica
#   pro caso de uso).
# Descomente abaixo só se quiser forçar Sonnet pra essas features também:
# ANTHROPIC_MODEL_CLASSIFICADOR=claude-sonnet-4-5
# ANTHROPIC_MODEL_AGENDA=claude-sonnet-4-5

# --- PROXY FINANCEIRO N8N ---
# Quando o classificador identifica mensagem financeira (boleto/pix/extrato),
# encaminhamos pro workflow "Conciliação Bancária WhatsApp" via webhook
# "PAC-NFSE → Conciliação (Proxy)" do n8n, que republica em RabbitMQ Meu_App.
# Sem essas envs configuradas, o handler usa fallback placeholder.
N8N_PROXY_URL=https://n8n-webhook.pacnobolso.com.br/webhook/pac-nfse-financeiro
N8N_PROXY_SECRET=trocar-aqui

# Identidade do app no payload (espelha o que a Evolution legada publica):
PAC_APP_NAME=Pac no Bolso
PAC_SUPORTE_PHONE=6286429305
PAC_SUPORTE_EMAIL=paixaoassessoriacontabil@gmail.com
PAC_SITE_URL=https://pacnobolso.com.br/

# Credenciais da Evolution que o n8n usa pra RESPONDER ao cliente.
# IMPORTANTE: depois da virada de chave (Semana 2b), deve apontar pra
# Evolution UNIFICADA (a que o cliente já conhece — não pra interna do
# agent-nfse). Por padrão usa a Evolution do PAC (pública).
PAC_EVO_SERVER_URL=https://evo.pacnobolso.com.br
PAC_EVO_API_KEY=trocar-aqui
PAC_EVO_INSTANCE=pac-no-bolso

# --- OPENAI (transcrição de áudio) ---
# Pega em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
# Modelo default: gpt-4o-mini-transcribe (lançado 03/2025 — 3-5x mais rápido
# e mais barato que whisper-1, qualidade igual ou superior em PT-BR).
# Override só se quiser qualidade superior (gpt-4o-transcribe, mais caro):
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# OPENAI_TRANSCRIBE_TIMEOUT_MS=25000

# --- FOCUS NFE (emissão) ---
# Pega no painel da Focus depois de criar conta
# Ambiente: homologacao (testes) ou producao (real)
FOCUS_NFE_TOKEN=
FOCUS_NFE_ENV=homologacao
FOCUS_NFE_BASE_URL_HOMOLOGACAO=https://homologacao.focusnfe.com.br
FOCUS_NFE_BASE_URL_PRODUCAO=https://api.focusnfe.com.br

# --- EVOLUTION API (WhatsApp) ---
# Roda na própria VPS. Após instalar, define essas variáveis:
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=defina_uma_chave_forte_aqui
EVOLUTION_INSTANCE_NAME=pac-bot
# Segredo opcional pra proteger POST /webhook (enviar em x-webhook-secret)
WEBHOOK_SECRET=

# --- BANCO ---
DB_PATH=./data/agent.db

# --- SEU NÚMERO DE ADMIN (validação humana primeiros 7 dias) ---
# Formato internacional sem +, ex: 5511999998888
ADMIN_WHATSAPP=

# --- MODO DE OPERAÇÃO ---
# manual_approval: bot pede sua aprovação antes de emitir (RECOMENDADO 1ª SEMANA)
# auto: bot emite direto após confirmação do cliente
APPROVAL_MODE=manual_approval

# --- CRON DIÁRIO: RESUMO MATINAL DA AGENDA ---
# Envia proativamente pro WhatsApp do dono o panorama do dia: compromissos
# de hoje, atrasados, próximos 7 dias e totais a pagar. Inspirado no
# concorrente Meu Assessor — cria hábito de consulta diária. Default: roda
# seg-sex 7h BRT. Domingo/sábado pula pra não invadir descanso.
# RESUMO_MATINAL_CRON_ENABLED=false      # desativa o cron
# RESUMO_MATINAL_CRON_EXPR="0 7 * * 1-5" # override schedule (cron 5 campos)
# RESUMO_MATINAL_CRON_TZ=America/Sao_Paulo
